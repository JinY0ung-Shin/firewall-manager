#!/usr/bin/env bash
# fw - Interactive Firewall Manager
# INPUT/DOCKER-USER 체인과 ipset 팀을 대화형으로 관리합니다.

VERSION="1.0.0"

# 스크립트 위치 감지 (설치 전: 로컬, 설치 후: /usr/local/lib/fw)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -d "${SCRIPT_DIR}/lib" ]]; then
    LIB_DIR="${SCRIPT_DIR}/lib"
else
    LIB_DIR="/usr/local/lib/fw"
fi

CONFIG_DIR="${SCRIPT_DIR}/config"

# ── 기반 모듈 로딩 ───────────────────────────────
if [[ ! -f "${LIB_DIR}/common.sh" ]]; then
    echo "오류: ${LIB_DIR}/common.sh 를 찾을 수 없습니다." >&2
    echo "install.sh를 먼저 실행하거나, fw 스크립트와 같은 디렉토리에 lib/ 폴더가 있는지 확인하세요." >&2
    exit 1
fi

source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/validators.sh"

# ── 비-interactive 모드 (systemd 부팅 등) ────────
if [[ $# -gt 0 ]]; then
    check_root
    check_dependencies
    init_config_dir
    detect_iptables_backend
    get_ssh_info

    case "$1" in
        load)
            source "${LIB_DIR}/persist.sh"
            shift
            persist_load "$@"
            exit $?
            ;;
        save)
            source "${LIB_DIR}/persist.sh"
            persist_save
            exit $?
            ;;
        sync)
            source "${LIB_DIR}/sync.sh"
            sync_menu
            exit $?
            ;;
        status)
            source "${LIB_DIR}/status.sh"
            show_status
            exit $?
            ;;
        version|--version|-v)
            echo "fw v${VERSION}"
            exit 0
            ;;
        help|--help|-h)
            echo ""
            echo "  fw - Interactive Firewall Manager v${VERSION}"
            echo ""
            echo "  사용법:"
            echo "    sudo fw              대화형 모드 시작"
            echo "    sudo fw status       현재 상태 보기"
            echo "    sudo fw save         현재 규칙 저장"
            echo "    sudo fw load         저장된 규칙 불러오기"
            echo "    sudo fw load --chain INPUT --quiet"
            echo "                         INPUT 체인만 조용히 복원 (부팅 시)"
            echo "    fw --version         버전 표시"
            echo "    fw --help            이 도움말"
            echo ""
            exit 0
            ;;
        *)
            error "알 수 없는 명령: $1"
            echo "  'fw --help'를 참조하세요."
            exit 1
            ;;
    esac
fi

# ── Interactive 모드 ─────────────────────────────
check_root
check_dependencies
init_config_dir
detect_iptables_backend
get_ssh_info

# 모듈 로딩
source "${LIB_DIR}/rule.sh"
source "${LIB_DIR}/team.sh"
source "${LIB_DIR}/persist.sh"
source "${LIB_DIR}/status.sh"
source "${LIB_DIR}/sync.sh"

# ── 기존 ipset 자동 가져오기 ────────────────────
auto_import_teams

# ── 메인 메뉴 루프 ──────────────────────────────
main_menu() {
    while true; do
        print_banner
        menu_select_main \
            "규칙 관리 (iptables)" \
            "팀 관리 (ipset)" \
            "저장 / 불러오기" \
            "동기화 (live ↔ config)" \
            "현재 상태 보기"
        local choice=$?

        case $choice in
            0) echo ""; info "종료합니다."; echo ""; exit 0 ;;
            1) rule_menu ;;
            2) team_menu ;;
            3) persist_menu ;;
            4) sync_menu ;;
            5) show_status; pause ;;
        esac
    done
}

main_menu
